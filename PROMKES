        function closeModals() {
            document.getElementById('modal-overlay').classList.add('hidden');
            document.querySelectorAll('#modal-overlay > div').forEach(el => el.classList.add('hidden'));
        }

        function calculatePersentase(sasaranId, cakupanId, persenId) {
            const sasaran = parseFloat(document.getElementById(sasaranId).value) || 0;
            const cakupan = parseFloat(document.getElementById(cakupanId).value) || 0;
            const persenEl = document.getElementById(persenId);
            
            if(sasaran > 0) {
                const pct = ((cakupan / sasaran) * 100).toFixed(1);
                persenEl.innerText = pct + '%';
                persenEl.className = pct >= 80 ? 'font-bold text-green-600' : (pct >= 50 ? 'font-bold text-amber-500' : 'font-bold text-red-500');
            } else {
                persenEl.innerText = '0%';
                persenEl.className = 'font-bold text-gray-500';
            }
        }

        function calculatePHBSTotal() {
            const kkTotal = parseFloat(document.getElementById('phbs-kk-total').value) || 0;
            if(kkTotal === 0) {
                document.getElementById('phbs-est-persen').textContent = '0%';
                return;
            }

            let avgSum = 0;
            for(let i=1; i<=10; i++) {
                let val = parseFloat(document.getElementById(`phbs-ind-${i}`).value) || 0;
                avgSum += val;
            }
            const avg = avgSum / 10;
            const estPct = Math.round((avg / kkTotal) * 100);
            
            document.getElementById('phbs-est-persen').textContent = `${estPct}%`;
        }

        function calculateKTRStatus() {
            let allYa = true;
            let hasEmpty = false;
            for(let i=1; i<=6; i++) {
                const val = document.getElementById(`ktr-ind-${i}`).value;
                if(val === "") hasEmpty = true;
                if(val === "Tidak") allYa = false;
            }

            const display = document.getElementById('ktr-status-display');
            const inputFinal = document.getElementById('ktr-status-final');

            if(hasEmpty) {
                display.textContent = "Menunggu...";
                display.className = "px-4 py-2 rounded-lg font-bold text-lg bg-gray-100 text-gray-400";
                inputFinal.value = "";
            } else if(allYa) {
                display.textContent = "PATUH KTR";
                display.className = "px-4 py-2 rounded-lg font-bold text-lg bg-green-100 text-green-700 border border-green-300";
                inputFinal.value = "Patuh";
            } else {
                display.textContent = "TIDAK PATUH";
                display.className = "px-4 py-2 rounded-lg font-bold text-lg bg-red-100 text-red-700 border border-red-300";
                inputFinal.value = "Tidak Patuh";
            }
        }

