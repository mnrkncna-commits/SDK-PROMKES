        function renderFaskes() {
            const grid = document.getElementById('faskes-grid');
            const searchTerm = document.getElementById('search-faskes').value.toLowerCase();
            
            grid.innerHTML = '';
            
            let filteredFaskes = faskes_list.filter(f => f.toLowerCase().includes(searchTerm));
            
            if (filteredFaskes.length === 0) {
                grid.innerHTML = '<div class="col-span-full py-10 text-center text-gray-500"><i class="fa-solid fa-hospital-user text-4xl mb-3 text-gray-300"></i><p>Faskes tidak ditemukan.</p></div>';
                return;
            }
            
            filteredFaskes.forEach(faskes => {
                
                // 1. Total Kader per faskes
                const totalKader = dataKader.filter(k => k.faskes === faskes).length;
                
                // 2 & 3. Total KK Ber-PHBS & Tidak Ber-PHBS per faskes
                const phbsFaskes = dataPHBS.filter(p => p.faskes === faskes && (globalYear === 'all' || p.tahun === globalYear));
                const totalKkBerPhbs = phbsFaskes.reduce((sum, p) => sum + parseInt(p.kk_sehat || 0), 0);
                const totalKkTidakBerPhbs = phbsFaskes.reduce((sum, p) => {
                    const total = parseInt(p.kk_total || 0);
                    const sehat = parseInt(p.kk_sehat || 0);
                    return sum + (total - sehat);
                }, 0);
                
                // 4 & 5. Total Sekolah Ber-KTR & Tidak Ber-KTR
                const ktrFaskesSekolah = dataKTR.filter(k => k.faskes === faskes && k.tatanan === 'Tempat Proses Belajar Mengajar' && (globalYear === 'all' || k.tahun === globalYear));
                const sekolahBerKtr = ktrFaskesSekolah.filter(k => k.status === 'Patuh').length;
                const sekolahTidakBerKtr = ktrFaskesSekolah.filter(k => k.status === 'Tidak Patuh').length;

                const card = document.createElement('div');
                card.className = 'bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-all flex flex-col';
                card.innerHTML = `
                    <div class="p-5 border-b border-gray-50 bg-gradient-to-r from-teal-500 to-teal-600 flex items-center gap-4">
                        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-teal-600 shadow-inner flex-shrink-0">
                            <i class="fa-solid fa-hospital text-xl"></i>
                        </div>
                        <h3 class="font-bold text-white text-lg leading-tight">${faskes}</h3>
                    </div>
                    <div class="p-5 flex-1 grid grid-cols-1 gap-3">
                        <div class="flex justify-between items-center bg-gray-50 p-3 rounded-xl border border-gray-100">
                            <div class="flex items-center gap-2 text-gray-700 text-sm font-semibold">
                                <i class="fa-solid fa-id-card-clip text-teal-500 w-5 text-center"></i> Total Kader
                            </div>
                            <span class="font-bold text-teal-800 bg-teal-100 px-2.5 py-1 rounded-lg text-sm">${totalKader}</span>
                        </div>
                        
                        <div class="flex justify-between items-center bg-indigo-50/50 p-3 rounded-xl border border-indigo-100/50">
                            <div class="flex items-center gap-2 text-gray-700 text-sm font-semibold">
                                <i class="fa-solid fa-house-chimney-user text-indigo-500 w-5 text-center"></i> KK Ber-PHBS
                            </div>
                            <span class="font-bold text-indigo-800 bg-indigo-100 px-2.5 py-1 rounded-lg text-sm">${totalKkBerPhbs}</span>
                        </div>
                        
                        <div class="flex justify-between items-center bg-red-50/50 p-3 rounded-xl border border-red-100/50">
                            <div class="flex items-center gap-2 text-gray-700 text-sm font-semibold">
                                <i class="fa-solid fa-house-chimney-crack text-red-500 w-5 text-center"></i> KK Tdk Ber-PHBS
                            </div>
                            <span class="font-bold text-red-800 bg-red-100 px-2.5 py-1 rounded-lg text-sm">${totalKkTidakBerPhbs}</span>
                        </div>
                        
                        <div class="flex justify-between items-center bg-green-50/50 p-3 rounded-xl border border-green-100/50">
                            <div class="flex items-center gap-2 text-gray-700 text-sm font-semibold">
                                <i class="fa-solid fa-school text-green-500 w-5 text-center"></i> Sekolah Ber-KTR
                            </div>
                            <span class="font-bold text-green-800 bg-green-100 px-2.5 py-1 rounded-lg text-sm">${sekolahBerKtr}</span>
                        </div>
                        
                        <div class="flex justify-between items-center bg-rose-50/50 p-3 rounded-xl border border-rose-100/50">
                            <div class="flex items-center gap-2 text-gray-700 text-sm font-semibold">
                                <i class="fa-solid fa-school-circle-xmark text-rose-500 w-5 text-center"></i> Sek. Tdk Ber-KTR
                            </div>
                            <span class="font-bold text-rose-800 bg-rose-100 px-2.5 py-1 rounded-lg text-sm">${sekolahTidakBerKtr}</span>
                        </div>
                    </div>
                    <div class="p-4 bg-gray-50 border-t border-gray-100 text-center">
                        <button onclick="filterPegawaiByFaskes('${faskes}')" class="w-full text-sm font-bold text-primary hover:text-secondary transition-colors py-1">
                            Lihat Laporan Penyuluhan <i class="fa-solid fa-arrow-right text-xs ml-1"></i>
                        </button>
