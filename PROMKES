                        <td class="p-4 border-b text-center font-bold text-primary">${p.str}</td>
                        <td class="p-4 border-b text-center text-gray-600">${p.kadaluarsa_str}</td>
                        <td class="p-4 border-b font-medium text-gray-700">${p.nama}</td>
                        <td class="p-4 border-b text-xs text-gray-600">${p.pendidikan}</td>
                        <td class="p-4 border-b">
                            <span class="px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wide ${p.status === 'Aktif' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-700'}">${p.status}</span>
                        </td>
                        <td class="p-4 border-b text-center">
                            <button onclick="editPegawai(${p.id})" class="w-8 h-8 rounded bg-amber-50 text-amber-600 hover:bg-amber-100 hover:text-amber-700 transition-colors" title="Edit"><i class="fa-solid fa-pen"></i></button>
