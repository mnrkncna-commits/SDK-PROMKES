        function renderTableNotaTugas() {
            const tbody = document.getElementById('table-notatugas-body');
            const emptyState = document.getElementById('table-notatugas-empty');
            const search = document.getElementById('search-notatugas').value.toLowerCase();
            const filterStatus = document.getElementById('filter-status-nota').value;
            
            tbody.innerHTML = '';
            let filtered = dataNotaTugas.filter(p => {
                const mSearch = p.nomor.toLowerCase().includes(search) || p.lokasi.toLowerCase().includes(search);
                const mStatus = filterStatus === "" || p.status === filterStatus;
                return mSearch && mStatus;
            });

            if (filtered.length === 0) {
                emptyState.classList.remove('hidden');
            } else {
                emptyState.classList.add('hidden');
                filtered.forEach((p, index) => {
                    const isAktif = p.status === 'Berlaku';
                    const tr = document.createElement('tr');
                    tr.className = "hover:bg-amber-50/30 transition-colors";
                    tr.innerHTML = `
                        <td class="p-4 border-b">${index + 1}</td>
                        <td class="p-4 border-b font-bold text-gray-800">${p.nomor}</td>
                        <td class="p-4 border-b text-sm font-semibold">${p.lokasi}</td>
                        <td class="p-4 border-b text-sm">${p.penyuluh}</td>
                        <td class="p-4 border-b text-sm text-gray-600">${p.faskes}</td>
                        <td class="p-4 border-b text-sm font-medium text-amber-700">${p.tmt}</td>
                        <td class="p-4 border-b">
                            <span class="px-3 py-1 rounded-full text-xs font-bold ${isAktif ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-600'}">${p.status}</span>
                        </td>
                        <td class="p-4 border-b text-center">
                            <button onclick="deleteData(dataNotaTugas, ${p.id}, renderTableNotaTugas)" class="w-8 h-8 rounded bg-red-50 text-red-500 hover:bg-red-100 hover:text-red-600"><i class="fa-solid fa-trash"></i></button>
                        </td>
                    `;
                    tbody.appendChild(tr);
                });
            }
        }

        function deleteData(array, id, renderCb) {
            const index = array.findIndex(i => i.id === id);
            if(index > -1) array.splice(index, 1);
            renderCb();
            renderDashboard();
            if(!document.getElementById('view-faskes').classList.contains('hidden')) renderFaskes();
        }

        function renderDashboard() {
            // Dashboard Totals
            document.getElementById('dash-total-kader').innerText = dataKader.length;
            
            const phbsYearly = dataPHBS.filter(p => globalYear === 'all' || p.tahun === globalYear);
            const totalSehat = phbsYearly.reduce((a, b) => a + parseInt(b.kk_sehat || 0), 0);
            const totalKK = phbsYearly.reduce((a, b) => a + parseInt(b.kk_total || 0), 0);
            document.getElementById('dash-total-kk-phbs').innerText = totalSehat;
            document.getElementById('dash-total-kk-nonphbs').innerText = totalKK - totalSehat;

            const ktrSekolah = dataKTR.filter(k => k.tatanan === 'Tempat Proses Belajar Mengajar' && (globalYear === 'all' || k.tahun === globalYear));
            document.getElementById('dash-total-sekolah-ktr').innerText = ktrSekolah.filter(k => k.status === 'Patuh').length;
            document.getElementById('dash-total-sekolah-nonktr').innerText = ktrSekolah.filter(k => k.status === 'Tidak Patuh').length;

            // Indikator Penyuluhan Terpopuler
            const activePegawai = dataPegawai.filter(p => p.status === 'Aktif' && (globalYear === 'all' || p.tahun === globalYear));
            
            const counts = { 'KIA & Ibu Hamil': { t:0, l:0, p:0 }, 'Penyakit Menular': { t:0, l:0, p:0 }, 'Stunting / Orang Tua Balita': { t:0, l:0, p:0 }, 'Remaja / Anak Sekolah': { t:0, l:0, p:0 }, 'Lainnya': { t:0, l:0, p:0 }};
            
            activePegawai.forEach(p => {
                let key = counts[p.profesi] ? p.profesi : 'Lainnya';
                counts[key].t++;
                counts[key].l += parseInt(p.sip || 0);
                counts[key].p += parseInt(p.kadaluarsa_sip || 0);
            });

            document.getElementById('dash-asn').innerText = counts['KIA & Ibu Hamil'].t;
            document.getElementById('dash-asn-l').innerText = counts['KIA & Ibu Hamil'].l;
            document.getElementById('dash-asn-p').innerText = counts['KIA & Ibu Hamil'].p;

            document.getElementById('dash-pppk').innerText = counts['Penyakit Menular'].t;
            document.getElementById('dash-pppk-l').innerText = counts['Penyakit Menular'].l;
            document.getElementById('dash-pppk-p').innerText = counts['Penyakit Menular'].p;

            document.getElementById('dash-k2').innerText = counts['Stunting / Orang Tua Balita'].t;
            document.getElementById('dash-k2-l').innerText = counts['Stunting / Orang Tua Balita'].l;
            document.getElementById('dash-k2-p').innerText = counts['Stunting / Orang Tua Balita'].p;

            document.getElementById('dash-blud').innerText = counts['Remaja / Anak Sekolah'].t;
            document.getElementById('dash-blud-l').innerText = counts['Remaja / Anak Sekolah'].l;
            document.getElementById('dash-blud-p').innerText = counts['Remaja / Anak Sekolah'].p;
        }

        function renderStatistik() {
            // Stats visualization logic using simple HTML Bars
            const containerTopik = document.getElementById('stats-nakes-container');
            const topiks = [...new Set(dataPegawai.map(p => p.profesi))];
            
            containerTopik.innerHTML = '';
            topiks.forEach(t => {
                const count = dataPegawai.filter(p => p.profesi === t).length;
                const pct = (count / dataPegawai.length) * 100 || 0;
                containerTopik.innerHTML += `
                    <div class="mb-3">
                        <div class="flex justify-between text-xs mb-1 font-semibold text-gray-700"><span>${t}</span> <span>${count} Giat</span></div>
                        <div class="w-full bg-gray-100 rounded-full h-2.5"><div class="bg-primary h-2.5 rounded-full" style="width: ${pct}%"></div></div>
                    </div>`;
            });

            // Format Penyuluhan
            const containerGolongan = document.getElementById('stats-golongan-container');
            const golongans = [...new Set(dataPegawai.map(p => p.sasaran))];
            containerGolongan.innerHTML = '';
            golongans.forEach(g => {
                const count = dataPegawai.filter(p => p.sasaran === g).length;
                const pct = (count / dataPegawai.length) * 100 || 0;
                containerGolongan.innerHTML += `
                    <div class="mb-3">
                        <div class="flex justify-between text-xs mb-1 font-semibold text-gray-700"><span>${g}</span> <span>${count}</span></div>
                        <div class="w-full bg-gray-100 rounded-full h-2.5"><div class="bg-teal-500 h-2.5 rounded-full" style="width: ${pct}%"></div></div>
                    </div>`;
            });

            // Pendidikan (Media)
            const containerPendidikan = document.getElementById('stats-pendidikan-container');
            const pendidikans = [...new Set(dataPegawai.map(p => p.pendidikan))];
            containerPendidikan.innerHTML = '';
            pendidikans.forEach(pd => {
                if(!pd) return;
                const count = dataPegawai.filter(p => p.pendidikan === pd).length;
                const pct = (count / dataPegawai.length) * 100 || 0;
                containerPendidikan.innerHTML += `
                    <div class="mb-3">
                        <div class="flex justify-between text-xs mb-1 font-semibold text-gray-700"><span>${pd}</span> <span>${count}</span></div>
                        <div class="w-full bg-gray-100 rounded-full h-2.5"><div class="bg-blue-500 h-2.5 rounded-full" style="width: ${pct}%"></div></div>
                    </div>`;
            });
        }
    </script>
