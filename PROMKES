<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistem Promkes, Penyuluhan & PHBS Kab. Nabire</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Pustaka pendukung untuk Unduhan Excel & PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        primary: '#0d9488', // Teal 600
                        secondary: '#0f766e', // Teal 700
                        accent: '#ccfbf1', // Teal 50
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f1f5f9; }
        .hide-scroll::-webkit-scrollbar { display: none; }
        .hide-scroll { -ms-overflow-style: none; scrollbar-width: none; }
        .glass-panel { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); }
        .menu-item.active { background-color: #ccfbf1; color: #0d9488; border-right: 4px solid #0d9488; font-weight: 600;}
        .animate-fade-in { animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="text-gray-800 flex h-screen overflow-hidden">

    <aside class="w-72 bg-white shadow-xl flex flex-col h-full z-40 flex-shrink-0 hidden md:flex absolute md:relative" id="sidebar">
        <div class="p-6 border-b border-gray-100 flex items-center gap-4">
            <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center text-white shadow-lg">
                <i class="fa-solid fa-bullhorn text-2xl"></i>
            </div>
            <div>
                <h1 class="font-bold text-base leading-tight text-gray-900">SIM PROMKES</h1>
                <p class="text-xs text-gray-500 font-medium font-mono">KAB. NABIRE</p>
            </div>
        </div>

       <div class="px-6 py-4 border-b border-gray-100 bg-teal-50/50 space-y-4">
            <div>
                <label class="block text-xs font-bold text-teal-800 mb-1"><i class="fa-solid fa-calendar-alt mr-1"></i> Tahun Periode Aktif</label>
                <select id="global-year-sidebar" onchange="changeGlobalYear(this.value)" class="w-full px-3 py-2 bg-white border border-teal-200 rounded-lg focus:ring-2 focus:ring-primary/50 outline-none font-bold text-teal-900 text-sm shadow-sm">
                    <option value="2026" selected>2026</option>
                    <option value="2027">2027</option>
                    <option value="2028">2028</option>
                    <option value="2029">2029</option>
                    <option value="2030">2030</option>
                </select>
            </div>
            
            <div>
                <label class="block text-xs font-bold text-teal-800 mb-1"><i class="fa-solid fa-calendar-days mr-1"></i> Bulan Aktif</label>
                <select id="global-month-sidebar" onchange="changeGlobalMonth(this.value)" class="w-full px-3 py-2 bg-white border border-teal-200 rounded-lg focus:ring-2 focus:ring-primary/50 outline-none font-bold text-teal-900 text-sm shadow-sm">
                    <option value="all" selected>Semua Bulan</option>
                    <option value="01">Januari</option>
                    <option value="02">Februari</option>
                    <option value="03">Maret</option>
                    <option value="04">April</option>
                    <option value="05">Mei</option>
                    <option value="06">Juni</option>
                    <option value="07">Juli</option>
                    <option value="08">Agustus</option>
                    <option value="09">September</option>
                    <option value="10">Oktober</option>
                    <option value="11">November</option>
                    <option value="12">Desember</option>
                </select>
            </div>
        </div>

        <nav class="flex-1 overflow-y-auto py-4 space-y-1 mt-2">
            <button onclick="navigate('dashboard')" id="nav-dashboard" class="menu-item active w-full text-left px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors flex items-center gap-3">
                <i class="fa-solid fa-chart-pie w-5 text-center"></i> Dashboard Promkes
            </button>
            <button onclick="navigate('statistik')" id="nav-statistik" class="menu-item w-full text-left px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors flex items-center gap-3">
                <i class="fa-solid fa-chart-simple w-5 text-center"></i> Statistik Topik
            </button>
            <button onclick="navigate('pegawai')" id="nav-pegawai" class="menu-item w-full text-left px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors flex items-center gap-3">
                <i class="fa-solid fa-file-invoice w-5 text-center"></i> Data Penyuluhan
            </button>
            <button onclick="navigate('posyandu')" id="nav-posyandu" class="menu-item w-full text-left px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors flex items-center gap-3">
                <i class="fa-solid fa-house-chimney-medical w-5 text-center"></i> Data Posyandu
            </button>
            <button onclick="navigate('kader')" id="nav-kader" class="menu-item w-full text-left px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors flex items-center gap-3">
                <i class="fa-solid fa-id-card-clip w-5 text-center text-teal-500"></i> Data Kader Posyandu
            </button>
            <button onclick="navigate('phbs')" id="nav-phbs" class="menu-item w-full text-left px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors flex items-center gap-3">
                <i class="fa-solid fa-house-chimney-user w-5 text-center text-indigo-500"></i> Data PHBS RT
            </button>
            <button onclick="navigate('ktr')" id="nav-ktr" class="menu-item w-full text-left px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors flex items-center gap-3">
                <i class="fa-solid fa-ban-smoking w-5 text-center text-rose-500"></i> Pemantauan KTR
            </button>
            <button onclick="navigate('faskes')" id="nav-faskes" class="menu-item w-full text-left px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors flex items-center gap-3">
                <i class="fa-solid fa-hospital w-5 text-center"></i> Faskes Terlibat
            </button>
            <button onclick="navigate('notatugas')" id="nav-notatugas" class="menu-item w-full text-left px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors flex items-center gap-3 border-t border-gray-100 mt-2 pt-4">
                <i class="fa-solid fa-file-signature w-5 text-center text-amber-600"></i> Rencana & Jadwal
            </button>
        </nav>
        
        <div class="p-4 border-t border-gray-100 bg-teal-50/50">
            <div class="flex items-center gap-2">
                <span id="db-status-dot" class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span>
                <span id="db-status-text" class="text-xs font-semibold text-gray-600">Sistem Aktif</span>
            </div>
            <p class="text-[10px] text-gray-400 mt-1">Sistem Informasi Manajemen Promkes</p>
        </div>
    </aside>

    <main class="flex-1 h-full overflow-y-auto bg-slate-50 relative w-full">
        <header class="md:hidden bg-white shadow-sm p-4 flex items-center justify-between sticky top-0 z-10">
            <div class="flex items-center gap-2 text-primary font-bold">
                <i class="fa-solid fa-bullhorn"></i> SIM Promkes Nabire
            </div>
            <div class="flex items-center gap-3">
                <span id="db-status-dot-mobile" class="w-2 h-2 rounded-full bg-emerald-500"></span>
                <button onclick="toggleSidebar()" class="text-gray-600 p-2"><i class="fa-solid fa-bars"></i></button>
            </div>
        </header>

        <div class="p-6 md:p-10 max-w-7xl mx-auto space-y-8">
            
            <!-- VIEW: DASHBOARD -->
            <div id="view-dashboard" class="view-section block animate-fade-in">
                <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
                    <div>
                        <h2 class="text-3xl font-bold text-gray-900 flex items-center flex-wrap gap-2">Ringkasan Kinerja Promkes <span class="text-sm font-bold text-primary bg-primary/10 px-2.5 py-1 rounded-lg border border-primary/20 active-year-display">2026</span></h2>
                        <p class="text-gray-500 mt-1">Laporan aktivitas penyuluhan kesehatan masyarakat di wilayah Kab. Nabire.</p>
                    </div>
                </div>

               <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
                    <!-- Total Kader -->
                    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 flex flex-col justify-center hover:shadow-md transition-shadow">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-teal-50 flex items-center justify-center text-teal-600 text-xl">
                                <i class="fa-solid fa-id-card-clip"></i>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500 font-medium">Total Kader</p>
                                <h3 id="dash-total-kader" class="text-2xl font-bold text-gray-800">0</h3>
                            </div>
                        </div>
                    </div>

                    <!-- Total KK Ber-PHBS -->
                    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 flex flex-col justify-center hover:shadow-md transition-shadow">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-indigo-50 flex items-center justify-center text-indigo-600 text-xl">
                                <i class="fa-solid fa-house-chimney-user"></i>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500 font-medium">Total KK Ber-PHBS</p>
                                <h3 id="dash-total-kk-phbs" class="text-2xl font-bold text-gray-800">0</h3>
                            </div>
                        </div>
                    </div>

                    <!-- Total KK Tidak Ber-PHBS -->
                    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 flex flex-col justify-center hover:shadow-md transition-shadow">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-red-500 text-xl">
                                <i class="fa-solid fa-house-chimney-crack"></i>
                            </div>
                            <div>
                                <p class="text-[11px] text-gray-500 font-medium">Total KK Tdk Ber-PHBS</p>
                                <h3 id="dash-total-kk-nonphbs" class="text-2xl font-bold text-gray-800">0</h3>
                            </div>
                        </div>
                    </div>

                    <!-- Total Sekolah Ber-KTR -->
                    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 flex flex-col justify-center hover:shadow-md transition-shadow">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-green-50 flex items-center justify-center text-green-600 text-xl">
                                <i class="fa-solid fa-school"></i>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500 font-medium">Sekolah Ber-KTR</p>
                                <h3 id="dash-total-sekolah-ktr" class="text-2xl font-bold text-gray-800">0</h3>
                            </div>
                        </div>
                    </div>

                    <!-- Total Sekolah Tidak Ber-KTR -->
                    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 flex flex-col justify-center hover:shadow-md transition-shadow">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-rose-50 flex items-center justify-center text-rose-600 text-xl">
                                <i class="fa-solid fa-school-circle-xmark"></i>
                            </div>
                            <div>
                                <p class="text-[11px] text-gray-500 font-medium">Sekolah Tdk Ber-KTR</p>
                                <h3 id="dash-total-sekolah-nonktr" class="text-2xl font-bold text-gray-800">0</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <h3 class="text-lg font-bold text-gray-800 mt-10 mb-4">Distribusi Indikator Penyuluhan Terpopuler (Selesai Pelaksanaan)</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-4">
                    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 flex flex-col justify-between border-l-4 border-l-emerald-500 gap-1.5">
                        <div class="flex justify-between items-center">
                            <span class="font-semibold text-gray-700 text-xs">KIA (Individu)</span>
                            <span id="dash-asn" class="text-lg font-bold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-lg">0</span>
                        </div>
                        <div class="flex items-center gap-2 text-[10px] text-gray-500 font-medium">
                            <span>L: <span id="dash-asn-l">0</span></span>
                            <span class="text-gray-300">|</span>
                            <span>P: <span id="dash-asn-p">0</span></span>
                        </div>
                    </div>
                    
                    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 flex flex-col justify-between border-l-4 border-l-blue-500 gap-1.5">
                        <div class="flex justify-between items-center">
                            <span class="font-semibold text-gray-700 text-xs">Penyakit Menular</span>
                            <span id="dash-pppk" class="text-lg font-bold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-lg">0</span>
                        </div>
                        <div class="flex items-center gap-2 text-[10px] text-gray-500 font-medium">
                            <span>L: <span id="dash-pppk-l">0</span></span>
                            <span class="text-gray-300">|</span>
                            <span>P: <span id="dash-pppk-p">0</span></span>
                        </div>
                    </div>
                    
                    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 flex flex-col justify-between border-l-4 border-l-yellow-500 gap-1.5">
                        <div class="flex justify-between items-center">
                            <span class="font-semibold text-gray-700 text-xs">PTM, Kesling & PHBS</span>
                            <span id="dash-k2" class="text-lg font-bold text-yellow-600 bg-yellow-50 px-2 py-0.5 rounded-lg">0</span>
                        </div>
                        <div class="flex items-center gap-2 text-[10px] text-gray-500 font-medium">
                            <span>L: <span id="dash-k2-l">0</span></span>
                            <span class="text-gray-300">|</span>
                            <span>P: <span id="dash-k2-p">0</span></span>
                        </div>
                    </div>
                    
                    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 flex flex-col justify-between border-l-4 border-l-indigo-500 gap-1.5">
                        <div class="flex justify-between items-center">
                            <span class="font-semibold text-gray-700 text-xs">Penyuluhan Sekolah</span>
                            <span id="dash-blud" class="text-lg font-bold text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded-lg">0</span>
                        </div>
                        <div class="flex items-center gap-2 text-[10px] text-gray-500 font-medium">
                            <span>L: <span id="dash-blud-l">0</span></span>
                            <span class="text-gray-300">|</span>
                            <span>P: <span id="dash-blud-p">0</span></span>
                        </div>
                    </div>
                    
                    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 flex flex-col justify-between border-l-4 border-l-gray-500 gap-1.5">
                        <div class="flex justify-between items-center">
                            <span class="font-semibold text-gray-700 text-xs">Lainnya / Umum</span>
                            <span id="dash-nonasn" class="text-lg font-bold text-gray-600 bg-gray-100 px-2 py-0.5 rounded-lg">0</span>
                        </div>
                        <div class="flex items-center gap-2 text-[10px] text-gray-500 font-medium">
                            <span>L: <span id="dash-nonasn-l">0</span></span>
                            <span class="text-gray-300">|</span>
                            <span>P: <span id="dash-nonasn-p">0</span></span>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- VIEW: DATA PENYULUHAN -->
            <div id="view-pegawai" class="view-section hidden animate-fade-in">
                <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
                    <div>
                        <h2 class="text-3xl font-bold text-gray-900 flex items-center flex-wrap gap-2">Daftar Kegiatan Penyuluhan <span class="text-sm font-bold text-primary bg-primary/10 px-2.5 py-1 rounded-lg border border-primary/20 active-year-display">2026</span></h2>
                        <p class="text-gray-500 mt-1">Kelola data pelaksanaan penyuluhan promosi kesehatan di Nabire.</p>
                    </div>
                    <div class="flex flex-wrap gap-3">
                        <button id="btn-add-pegawai" onclick="showAddPegawaiModal()" class="bg-primary hover:bg-secondary text-white px-5 py-2.5 rounded-lg font-medium shadow-md shadow-primary/30 transition-all flex items-center gap-2">
                            <i class="fa-solid fa-plus"></i> Input Laporan Penyuluhan
                        </button>
                    </div>
                </div>

                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="p-5 border-b border-gray-100 bg-gray-50/50 flex flex-col lg:flex-row gap-4">
                        <div class="relative flex-1">
                            <i class="fa-solid fa-search absolute left-4 top-3 text-gray-400"></i>
                            <input type="text" id="search-pegawai" oninput="renderTablePegawai()" placeholder="Cari topik, penyuluh, atau lokasi..." class="w-full pl-11 pr-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary/50 text-sm">
                        </div>
                        <select id="filter-faskes" onchange="renderTablePegawai()" class="px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary/50 text-sm bg-white min-w-[180px]">
                            <option value="">Semua Faskes Pelaksana</option>
                        </select>
                        <select id="filter-jalur" onchange="renderTablePegawai()" class="px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary/50 text-sm bg-white min-w-[150px]">
                            <option value="">Semua Jenis Lokasi</option>
                            <option value="Lama">Dalam Faskes</option>
                            <option value="Mutasi">Luar Faskes / Lapangan</option>
                        </select>
                        <select id="filter-status-aktif" onchange="renderTablePegawai()" class="px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary/50 text-sm bg-white min-w-[180px]">
                            <option value="">Semua Status Pelaksanaan</option>
                            <option value="Aktif" selected>Hanya Selesai</option>
                            <option value="Non-Aktif">Direncanakan / Draft</option>
                        </select>
                    </div>
                    
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[1500px]">
                            <thead>
                                <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wider">
                                    <th class="p-4 font-semibold w-12 border-b">No</th>
                                    <th class="p-4 font-semibold border-b">Tanggal & Lokasi</th>
                                    <th class="p-4 font-semibold border-b">Topik / Sasaran Detail</th>
                                    <th class="p-4 font-semibold border-b">Faskes Pelaksana</th>
                                    <th class="p-4 font-semibold border-b">Indikator</th>
                                    <th class="p-4 font-semibold text-center border-b">Jml Peserta (OAP)</th>
                                    <th class="p-4 font-semibold text-center border-b">Jml Peserta (Non-OAP)</th>
                                    <th class="p-4 font-semibold border-b">Penyuluh / Narsum</th>
                                    <th class="p-4 border-b">Media Edukasi</th>
                                    <th class="p-4 border-b">Status</th>
                                    <th class="p-4 text-center w-24 border-b">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="table-pegawai-body" class="text-sm divide-y divide-gray-100">
                                <!-- Data render here -->
                            </tbody>
                        </table>
                    </div>
                    <div id="table-empty-state" class="hidden py-10 text-center text-gray-500">
                        <i class="fa-solid fa-folder-open text-4xl mb-3 text-gray-300"></i>
                        <p>Laporan penyuluhan belum ditemukan. Silakan sesuaikan filter atau tambahkan laporan baru.</p>
                    </div>
                </div>
            </div>

            <!-- VIEW: STATISTIK -->
            <div id="view-statistik" class="view-section hidden animate-fade-in">
                <div class="mb-8">
                    <h2 class="text-3xl font-bold text-gray-900 flex items-center flex-wrap gap-2">Statistik Penyuluhan Promkes <span class="text-sm font-bold text-primary bg-primary/10 px-2.5 py-1 rounded-lg border border-primary/20 active-year-display">2026</span></h2>
                    <p class="text-gray-500 mt-1">Distribusi berdasarkan rincian topik, sasaran, dan media penyuluhan.</p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <h3 class="font-bold text-lg text-gray-800 mb-6 flex items-center gap-2"><i class="fa-solid fa-book-open-reader text-primary"></i> Distribusi Berdasarkan Topik Edukasi</h3>
                        <div id="stats-nakes-container" class="space-y-4 max-h-[600px] overflow-y-auto pr-3 hide-scroll">
                            <!-- JS will populate -->
                        </div>
                    </div>
                    
                    <div class="space-y-6">
                        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                            <h3 class="font-bold text-lg text-gray-800 mb-4 flex items-center gap-2"><i class="fa-solid fa-photo-film text-blue-500"></i> Media Edukasi yang Digunakan</h3>
                            <div id="stats-pendidikan-container" class="space-y-3">
                                <!-- JS will populate -->
                            </div>
                        </div>

                        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                            <h3 class="font-bold text-lg text-gray-800 mb-4 flex items-center gap-2"><i class="fa-solid fa-users-line text-teal-600"></i> Distribusi Berdasarkan Sasaran Utama</h3>
                            <div id="stats-golongan-container" class="space-y-3">
                                <!-- JS will populate -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- VIEW: DATA POSYANDU -->
            <div id="view-posyandu" class="view-section hidden animate-fade-in">
                <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
                    <div>
