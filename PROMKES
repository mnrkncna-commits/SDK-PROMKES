            faskes_list.forEach(f => {
                optionsHTML += `<option value="${f}">${f}</option>`;
            });
            
            selects.forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    if(id.startsWith('filter')) {
                        el.innerHTML = '<option value="">Semua Faskes</option>' + optionsHTML.replace('<option value="">-- Pilih Faskes --</option>', '');
                    } else {
                        el.innerHTML = optionsHTML;
                    }
                }
            });
