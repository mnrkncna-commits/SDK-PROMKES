            const filterStatus = document.getElementById('filter-status-aktif').value;
            
            tbody.innerHTML = '';
            
            let filtered = dataPegawai.filter(p => {
                const matchSearch = p.nama.toLowerCase().includes(search) || p.profesi.toLowerCase().includes(search) || p.instansi.toLowerCase().includes(search);
                const matchFaskes = filterFaskes === "" || p.faskes === filterFaskes;
                const matchJalur = filterJalur === "" || p.lokasi_jenis === filterJalur;
                const matchStatus = filterStatus === "" || p.status === filterStatus;
                const matchYear = globalYear === 'all' || p.tahun === globalYear;
                const matchMonth = globalMonth === 'all' || p.bulan === globalMonth;
                
                return matchSearch && matchFaskes && matchJalur && matchStatus && matchYear && matchMonth;
