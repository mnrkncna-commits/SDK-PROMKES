        function populateFaskesDropdowns() {
            const selects = ['input-faskes', 'filter-faskes', 'pos-faskes', 'filter-faskes-posyandu', 'kader-puskesmas', 'phbs-faskes', 'ktr-faskes', 'notatugas-faskes'];
